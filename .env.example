# Project root (auto-detected in most cases)
# PROJECT_ROOT=/path/to/Cross-Website-GUI-Grounding-with-Verifiable-Reward-Optimization

# HuggingFace
HF_TOKEN=your_huggingface_token_here
HF_HOME=/path/to/hf_cache
# Optional mirror endpoint when huggingface.co is blocked
# HF_ENDPOINT=https://hf-mirror.com

# Weights & Biases
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=gui-grounding
WANDB_ENTITY=your_entity

# Model cache
MODEL_CACHE_DIR=/path/to/model_cache

# Data paths (override defaults in configs)
# DATA_RAW_DIR=data/raw
# DATA_PROCESSED_DIR=data/processed

# GPU settings
CUDA_VISIBLE_DEVICES=0
